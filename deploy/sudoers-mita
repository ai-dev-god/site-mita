# Drop this file at /etc/sudoers.d/mita on the production server.
# Allows the mita user to manage app services and Apache config — no full sudo.
#
# Install with:
#   sudo visudo -c -f /path/to/sudoers-mita   # validate first
#   sudo cp sudoers-mita /etc/sudoers.d/mita
#   sudo chmod 440 /etc/sudoers.d/mita

# Service management
aurel ALL=(root) NOPASSWD: /usr/bin/systemctl restart lmbsc-api
aurel ALL=(root) NOPASSWD: /usr/bin/systemctl restart lmbsc-web
aurel ALL=(root) NOPASSWD: /usr/bin/systemctl restart lmbsc-deploy
aurel ALL=(root) NOPASSWD: /usr/bin/systemctl reload apache2
aurel ALL=(root) NOPASSWD: /usr/bin/systemctl daemon-reload
aurel ALL=(root) NOPASSWD: /usr/bin/systemctl enable lmbsc-api lmbsc-web lmbsc-deploy

# Watchdog — cPanel httpd reload
aurel ALL=(root) NOPASSWD: /usr/sbin/apachectl

# Service file installation
aurel ALL=(root) NOPASSWD: /usr/bin/cp /home/aurel/mita/deploy/lmbsc-api.service /etc/systemd/system/lmbsc-api.service
aurel ALL=(root) NOPASSWD: /usr/bin/cp /home/aurel/mita/deploy/lmbsc-web.service /etc/systemd/system/lmbsc-web.service

# Apache config
aurel ALL=(root) NOPASSWD: /usr/bin/cp /home/aurel/mita/deploy/apache/lamitabiciclista.conf /etc/apache2/sites-available/lamitabiciclista.conf
aurel ALL=(root) NOPASSWD: /usr/sbin/a2enmod
aurel ALL=(root) NOPASSWD: /usr/sbin/a2ensite
aurel ALL=(root) NOPASSWD: /usr/sbin/apache2ctl
