# ============================================================
# LMBSC Hospitality Platform — Production environment variables
# Copy to /home/mita/lmbsc/.env.production on the server
# NEVER commit this file with real values
# ============================================================

# App
ENVIRONMENT=production
DEBUG=false
APP_VERSION=0.1.0

# Database (PostgreSQL 16 + TimescaleDB)
# Format: postgresql+asyncpg://USER:PASS@HOST/DBNAME
DATABASE_URL=postgresql+asyncpg://lmbsc:CHANGE_ME@localhost/lmbsc_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis 7
REDIS_URL=redis://localhost:6379/0

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_32_CHARS_MIN
PII_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_AES_KEY

# Stripe (optional at MVP — leave empty to disable payment flows)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio SMS (get from console.twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+40XXXXXXXXX

# Resend email (get from resend.com/api-keys)
RESEND_API_KEY=
RESEND_FROM_ADDRESS=reservations@lamitabiciclista.ro

# App base URL (used in tokenized cancel/modify links)
APP_BASE_URL=https://app.lamitabiciclista.ro

# CORS — server IP: 80.251.153.105 (DNS already live)
ALLOWED_ORIGINS=["https://app.lamitabiciclista.ro","https://lamitabiciclista.ro"]

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Clerk Auth
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_CHANGE_ME
CLERK_SECRET_KEY=sk_live_CHANGE_ME
# Frontend API domain — found in Clerk dashboard → Domains
# Example: "clerk.lamitabiciclista.ro" or "<slug>.clerk.accounts.dev" (dev only)
CLERK_FRONTEND_API=clerk.lamitabiciclista.ro

# Sentry (optional)
SENTRY_DSN=
